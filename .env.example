# ====================================================================
# Privacy Redactor - Environment Configuration Template
# ====================================================================
# Copy this file to `.env` and fill in your actual values
# DO NOT commit `.env` to git (it's in .gitignore)
# ====================================================================

# ── Backend Database (Optional) ───────────────────────────────────
# If DATABASE_URL is not set, the backend runs without telemetry logging
# For local testing without PostgreSQL, you can leave this commented out

# DATABASE_URL=postgresql://username:password@localhost:5432/privacy_redactor
# Example for PostgreSQL on Railway or cloud:
# DATABASE_URL=postgresql://user:pass@db.railway.app:5432/privacy_redactor

# ── Groq AI API (Optional but Recommended) ────────────────────────
# Get your API key from: https://console.groq.com
# Used for contextual entity disambiguation (Apple fruit vs Apple company)
# If not set, AI filtering is disabled but basic redaction still works

GROQ_API_KEY=your_groq_api_key_here

# ── Confidence Threshold ──────────────────────────────────────────
# Entities with confidence scores below this are filtered out
# Range: 0.0 - 1.0 (default: 0.6)
# Lower = more entities detected (higher false positives)
# Higher = fewer entities detected (higher false negatives)

MIN_CONFIDENCE_THRESHOLD=0.6

# ── Tesseract OCR Path (Only for Image/Scanned PDF Redaction) ─────
# Set only if Tesseract is not in the system PATH
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract or /opt/homebrew/bin/tesseract

# TESSERACT_CMD=/usr/bin/tesseract

# ── Frontend Configuration ────────────────────────────────────────
# This should match where your backend is running
# For local development: http://127.0.0.1:8000 or http://localhost:8000

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ====================================================================
# SETUP INSTRUCTIONS
# ====================================================================
#
# 1. BACKEND SETUP (FastAPI):
#    cd to project root
#    pip install -r requirements.txt
#    export GROQ_API_KEY="your_key_here"  (or set in .env)
#    uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
#
# 2. FRONTEND SETUP (Next.js):
#    cd privacy_redactor_frontend
#    Create .env.local with NEXT_PUBLIC_API_URL
#    npm install
#    npm run dev
#    Open http://localhost:3000
#
# 3. TEST HEALTH:
#    curl http://127.0.0.1:8000/health
#    Should return: {"status": "ok", "service": "Privacy & Compliance Redactor API", ...}
#
# ====================================================================
# DEPENDENCIES
# ====================================================================
#
# System Requirements:
# - Python 3.10+ (Backend)
# - Node.js 18+ (Frontend)
# - PostgreSQL (Optional, for telemetry logging)
# - Tesseract OCR (Optional, for image/scanned PDF redaction)
#
# Install Tesseract:
# - Windows: Download from https://github.com/UB-Mannheim/tesseract/wiki
# - macOS: brew install tesseract
# - Linux: sudo apt-get install tesseract-ocr
#
# ====================================================================
